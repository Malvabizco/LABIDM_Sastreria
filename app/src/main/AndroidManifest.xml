<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CrearTicket">

        <!-- LOGIN (pantalla inicial) -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- DASHBOARDS -->
        <activity android:name=".AdminDashboardActivity" android:exported="false" />
        <activity android:name=".SastreDashboardActivity" android:exported="false" />
        <activity android:name=".ReportesAdmin" />

        <!-- USUARIOS -->
        <activity android:name=".ConsultarUsuariosActivity" android:exported="false" />
        <activity android:name=".CrearUsuarioActivity" android:exported="false" />
        <activity android:name=".DetallesUsuarioActivity" android:exported="false" />

        <!-- CLIENTES -->
        <activity android:name=".ClientesActivity" android:exported="false" />
        <activity android:name=".CrearClienteActivity" android:exported="false" />
        <activity android:name=".DetallesClienteActivity" android:exported="false" />

        <!-- TICKETS -->
        <activity android:name=".ConsultarTicketsActivity" android:exported="false" />
        <activity android:name=".CrearTicketActivity" android:exported="false" />
        <activity android:name=".DetallesTicketActivity" android:exported="false" />
        

    </application>

</manifest>